# 服务配置
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# MySQL配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root123456
MYSQL_DATABASE=city_memory
MYSQL_CONNECTION_LIMIT=10

# MongoDB配置
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USER=admin
MONGODB_PASSWORD=admin123456
MONGODB_DATABASE=city_memory
MONGODB_AUTH_SOURCE=admin

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 微信小程序配置
WECHAT_APPID=your-wechat-appid
WECHAT_SECRET=your-wechat-secret

# 日志配置
LOG_LEVEL=info
LOG_DIR=logs

# 文件上传配置
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# 分页配置
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# 游戏配置
INITIAL_TICKETS=5
TICKET_RECOVERY_INTERVAL=1800000
MAX_TICKETS=10
STAR_REWARD_PER_LEVEL=3
