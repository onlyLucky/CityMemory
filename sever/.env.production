NODE_ENV=production
PORT=3000
API_PREFIX=/api/v1

# MySQL配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=citytrace

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MongoDB配置
MONGODB_URI=mongodb://localhost:27017/citytrace

# JWT配置
JWT_SECRET=your-production-secret-key
JWT_EXPIRES_IN=7d

# 微信配置
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# 日志配置
LOG_LEVEL=info
LOG_FILE_PATH=./logs
